{
	"name": "kenari",
	"version": "0.1.0",
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.3",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"private": false,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:node": "vite build",
		"build:edge": "DEPLOY_TARGET=cloudflare vite build",
		"preview": "vite preview",
		"prepare": "playwright install && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"db:push": "bun --env-file=.env.local run drizzle-kit push",
		"db:push:prod": "bun --env-file=.env.production run drizzle-kit push",
		"db:generate": "bun --env-file=.env.local run drizzle-kit generate",
		"db:migrate": "bun --env-file=.env.local run drizzle-kit migrate",
		"db:studio": "bun --env-file=.env.local run drizzle-kit studio",
		"db:drop": "bun --env-file=.env.local run drizzle-kit drop"
	},
	"type": "module",
	"dependencies": {
		"@libsql/client": "^0.17.2",
		"@lucia-auth/adapter-drizzle": "^1.1.0",
		"@node-rs/argon2": "^2.0.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-node": "^5.5.4",
		"arctic": "^3.7.0",
		"lucia": "^3.2.2",
		"nanoid": "^5.1.9"
	},
	"description": "A canary for your monitoring gateway"
}