# =============================================================================
# Monitor Gateway — Environment Template
# Copy to .env.local (development) or .env.production (self-hosted).
# For edge deployment, set variables in your platform dashboard.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
ORIGIN=http://localhost:5173

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# Development / self-hosted:  file:./monitor.db
# Edge (Cloudflare Workers):  libsql://your-db.turso.io
DATABASE_URL=file:./monitor.db

# Required only for Turso remote (edge deployment)
DATABASE_AUTH_TOKEN=

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
# See docs/GITHUB_OAUTH.md for setup instructions
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Whitelist — comma separated GitHub usernames and/or org names
# Leave both empty to allow ANY GitHub user (not recommended for production)
GITHUB_ALLOWED_USERS=
GITHUB_ALLOWED_ORGS=

# ── Upstream Tools ────────────────────────────────────────────────────────────
# Self-hosted (Docker): use internal container names
# Edge deployment: use public URLs

# Uptime Kuma
KUMA_URL=http://localhost:3001
KUMA_API_TOKEN=

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=
