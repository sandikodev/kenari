# =============================================================================
# Monitor Gateway — Environment Template
# Copy to .env.local (development) or .env.production (self-hosted).
# For edge deployment, set variables in your platform dashboard.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
ORIGIN=http://localhost:5173

# ── Auth (better-auth) ────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# Development / self-hosted:  file:./monitor.db
# Edge (Cloudflare Workers):  libsql://your-db.turso.io
DATABASE_URL=file:./monitor.db

# Required only for Turso remote (edge deployment)
DATABASE_AUTH_TOKEN=

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
# Create at: https://github.com/settings/developers
# Callback URL: {ORIGIN}/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Upstream Tools ────────────────────────────────────────────────────────────
# Self-hosted (Docker): use internal container names
# Edge deployment: use public URLs

# Uptime Kuma
KUMA_URL=http://localhost:3001
KUMA_API_TOKEN=

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=
