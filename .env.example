# =============================================================================
# Monitor Gateway — Environment Template
# Copy to .env.local (development) or .env.production (self-hosted).
# For edge deployment, set variables in your platform dashboard.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
ORIGIN=http://localhost:5173

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# Development / self-hosted:  file:./monitor.db
# Edge (Cloudflare Workers):  libsql://your-db.turso.io
DATABASE_URL=file:./monitor.db

# Required only for Turso remote (edge deployment)
DATABASE_AUTH_TOKEN=

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
# See docs/GITHUB_OAUTH.md for setup instructions
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Whitelist — comma separated GitHub usernames and/or org names
# Leave both empty to allow ANY GitHub user (not recommended for production)
GITHUB_ALLOWED_USERS=
GITHUB_ALLOWED_ORGS=

# ── Notifications (optional) ──────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Self-hosted (Docker): use internal container names
# Edge deployment: use public URLs

# ── Upstream Tools (optional — remove vars to disable) ────────────────────────

# Uptime Kuma
KUMA_URL=http://localhost:3001
KUMA_NAME=Uptime Kuma
KUMA_API_TOKEN=

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_NAME=Grafana
GRAFANA_PROXY_USER=admin
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# Custom routes — add any proxy target as JSON array
# { id, name, icon, description, proxyPath, upstreamUrl, authHeader?, allowedRoles? }
# KENARI_ROUTES='[{"id":"myapp","name":"My App","icon":"🚀","description":"My service","proxyPath":"/myapp","upstreamUrl":"http://myapp:8080"}]'
KENARI_ROUTES=

# Webhook notifications (optional) — Slack, Discord, or any HTTP endpoint
# Slack: https://hooks.slack.com/services/xxx
# Discord: https://discord.com/api/webhooks/xxx
WEBHOOK_URL=
