# =============================================================================
# Monitor Gateway — Edge Deployment (Cloudflare Pages/Workers)
# Set these as environment variables in Cloudflare dashboard.
# This file is for reference only — NOT committed to git.
# =============================================================================

# App
ORIGIN=https://monitor.yourdomain.com

# Auth
BETTER_AUTH_SECRET=

# Database — Turso remote (required for edge, no local file access)
# Create at: https://turso.tech
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=

# GitHub OAuth
# Callback URL: https://monitor.yourdomain.com/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Upstream tools — must be publicly accessible URLs
# (edge workers cannot reach private Docker networks)
KUMA_API_TOKEN=
GRAFANA_USER=admin
GRAFANA_PASSWORD=

KUMA_URL=https://uptime.yourdomain.com
GRAFANA_URL=https://grafana.yourdomain.com
